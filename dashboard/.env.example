# PORNBLOCK dashboard — Vite environment variables
# Copy this to dashboard/.env and fill in the values.

# Clerk publishable key — get from https://dashboard.clerk.com → API Keys
# This value is safe to expose in the browser bundle (it's public by design).
VITE_CLERK_PUBLISHABLE_KEY=<CHANGE_ME>

# API base URL — the Railway backend URL in production, localhost in dev
VITE_API_URL=http://localhost:3000
