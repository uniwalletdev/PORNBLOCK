{
  "name": "pornblock-api",
  "version": "1.0.0",
  "description": "PORNBLOCK anti-pornography protection platform — REST API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "build": "echo 'No compile step for plain Node — linting only' && npm run lint",
    "lint": "eslint src tests --ext .js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "migrate:status": "node-pg-migrate status",
    "seed": "node scripts/seed.js",
    "seed:hagezi": "node scripts/import-hagezi.js",
    "dns": "node src/dns/server.js",
    "dns:dev": "nodemon src/dns/server.js",
    "dns:migrate": "node src/dns/migrate.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dns2": "^2.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.9.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterFramework": [],
    "globalSetup": "./tests/setup/globalSetup.js",
    "globalTeardown": "./tests/setup/globalTeardown.js",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/db/schema.sql"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
