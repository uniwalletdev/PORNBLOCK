<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.pornblock.app</domain>
        <!-- Certificate pinning for the API server.
             Replace with actual SHA-256 pins before release:
             openssl s_client -connect api.pornblock.app:443 | \
               openssl x509 -pubkey -noout | openssl pkey -pubin -outform der | \
               openssl dgst -sha256 -binary | openssl enc -base64
        -->
        <pin-set expiration="2027-03-24">
            <pin digest="SHA-256">REPLACE_WITH_ACTUAL_PIN_PRIMARY==</pin>
            <pin digest="SHA-256">REPLACE_WITH_ACTUAL_PIN_BACKUP===</pin>
        </pin-set>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
