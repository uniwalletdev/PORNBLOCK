# Environment secrets — NEVER commit
.env
.env.test
*.env.local
.env.production.local
# dashboard/.env.production is intentionally committed (publishable key only — safe to be public)

# Node
node_modules/
npm-debug.log*
.npm

# Build outputs
dist/
build/
*.tsbuildinfo

# Coverage
coverage/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo

# Docker volumes (if bind-mounted locally)
postgres_data/
redis_data/

# Android build outputs
android/.gradle/
android/app/build/
android/build/
android/local.properties
*.apk
*.aab
*.keystore
*.jks

# TFLite model (large binary — distribute separately)
android/app/src/main/assets/*.tflite
