# ─────────────────────────────────────────────────────────────────────────────
#  PORNBLOCK — environment variables
#  Copy this file to .env and fill in every value marked <CHANGE_ME>
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PORT=3000

# ── Clerk auth (https://dashboard.clerk.com → API Keys) ──────────────────────
CLERK_SECRET_KEY=<CHANGE_ME>
# For the dashboard (dashboard/.env):
# VITE_CLERK_PUBLISHABLE_KEY=<CHANGE_ME>

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pornblock
DB_USER=pornblock
DB_PASSWORD=<CHANGE_ME>
# Full connection string (used by node-pg-migrate)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=
# Leave REDIS_PASSWORD blank for no-auth (default in development)
REDIS_URL=redis://127.0.0.1:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<CHANGE_ME_min_64_chars>
JWT_EXPIRES_IN=7d

# ── DNS server ────────────────────────────────────────────────────────────────
DNS_PORT=5353
DNS_HTTP_PORT=8053
DNS_UPSTREAM=1.1.1.1
DNS_ADMIN_SECRET=<CHANGE_ME>

# ── Frontend / Dashboard ──────────────────────────────────────────────────────
DASHBOARD_PORT=5173
VITE_API_URL=http://localhost:3000

# ── Seed / testing ────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@pornblock.local
SEED_ADMIN_PASSWORD=<CHANGE_ME_strong_password>
SEED_TEST_EMAIL=testuser@pornblock.local
SEED_TEST_PASSWORD=TestPass123!

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key from Stripe dashboard → Developers → API Keys
STRIPE_SECRET=<CHANGE_ME_or_leave_blank>
# Webhook signing secret from Stripe dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=<CHANGE_ME_or_leave_blank>
# Price IDs from Stripe dashboard → Products (use Price ID, starts with price_)
STRIPE_PRICE_PERSONAL=<CHANGE_ME>
STRIPE_PRICE_FAMILY=<CHANGE_ME>

# ── Email (Resend — https://resend.com) ───────────────────────────────────────
# Leave blank in development; emails will be skipped with a console log.
RESEND_API_KEY=<CHANGE_ME>
# Sender address shown in outgoing emails (must be a verified domain in Resend)
EMAIL_FROM=PORNBLOCK <noreply@pornblock.app>

# ── node-pg-migrate ───────────────────────────────────────────────────────────
# These are read automatically by node-pg-migrate when DATABASE_URL is set
MIGRATIONS_DIR=migrations
